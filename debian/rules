#!/usr/bin/make -f

export DEB_BUILD_MAINT_OPTIONS = hardening=+all

# cargo writes to $HOME during build; keep it inside the build tree so
# sandboxed builders (pbuilder, sbuild) don't fail on HOME=/nonexistent.
export CARGO_HOME = $(CURDIR)/.cargo-home

%:
	dh $@

override_dh_auto_build:
	cargo build --release --locked

override_dh_auto_test:
	# skip — no unit tests yet, and we don't want the build to pull network

override_dh_auto_clean:
	cargo clean || true
	rm -rf $(CARGO_HOME)
