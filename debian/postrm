#!/bin/sh
# postrm script for cosmic-applet-bongo-penguin
set -e

case "$1" in
    remove|purge|upgrade|failed-upgrade|abort-install|abort-upgrade|disappear)
        # Per-user data lives under ~/.local/share/bongo-penguin-cosmic/
        # and ~/.cache/bongo-penguin.log — we intentionally do NOT touch
        # those, so reinstalling restores the user's keystroke counter.
        ;;

    *)
        echo "postrm called with unknown argument \`$1'" >&2
        exit 1
        ;;
esac

exit 0
